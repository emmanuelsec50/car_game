command = ''
start = False
speed = 0
began = False
max_speed = 200
fuel = 200
max_fuel = 200
full = True
gear = 1
fuel_notice = False
print('''
> help -To display commands
> start - To start the car
> stop - To stop the car
> quit - To exit
> acc - To accelerate your car
> dec - To decelerate your car
> speed - To display your speed
> refill - To refill your tank
> fuel - To display your remaining fuel capacity
''')
while True:
    if  not full:
        if start:
            print('Car has stopped since fuel is depleted')
            began = False
            start = False
    command = input('> ').lower()
    if fuel > 0:
        full = True
    elif fuel == 0:
        full = False
    if fuel <= 0:
        start = False
        began = False
        full = False
    
        # starting
    if command == 'start':
        if fuel <= 0:
            start = False
            began = False
            full = False
        if start and full:
            print('Car is already started')
        elif not start and full:
            fuel -= 1
            began = False
            speed = 0
            print(f'Car started!')
            start = True
            if fuel <= 0:
                start = False
                began = False
                full = False
        elif not full:
            print('Please refill your car!')
            # stopping
    elif command == 'stop':
        if start:
            if speed > 0:
                gear = 1
                print(f'Car is stopped from {speed}')
            else:
                print('Car is already stopped!')
            start = False
            speed = 0
        elif not start:
            print('Car is not started yet!')
#   accellerate      
    elif command == 'acc':
        if start and full:
            if fuel <= 0:
                fuel_notice =  True
                print('You are out of fuel!')
                start = False
                began = False
                full = False
                fuel = 0
                speed = 0
            elif fuel < 50 and not fuel_notice:
                print('Your fuel is below 50L')
            began = True
            if speed == max_speed:
                print(f'You have reached the speed limit of {speed}')
            elif speed >= 180:
                if gear == 3:
                    print(f'You approaching a speed limit of {max_speed}')
                    speed = speed + 10
                    fuel = fuel - 20
                    print(f'Speed increased to {speed}')
                    if fuel <= 0:
                        fuel_notice =  True
                        print('You are out of fuel!')
                        start = False
                        began = False
                        full = False
                        fuel = 0
                        speed = 0
                    elif fuel < 50 and not fuel_notice:
                        print('Your fuel is below 50L')
                elif gear < 3:
                    print('You are not in the third gear')
            
            elif speed >= 100:
                if gear == 2:
                    print(f'You approaching a speed limit of {max_speed}')
                    speed = speed + 10
                    fuel = fuel - 20
                    print(f'Speed increased to {speed}')
                    if fuel <= 0:
                        fuel_notice =  True
                        print('You are out of fuel!')
                        start = False
                        began = False
                        full = False
                        fuel = 0
                        speed = 0
                    elif fuel < 50 and not fuel_notice:
                        print('Your fuel is below 50L')
                elif gear != 2:
                    print('You are in the wrong gear')
            elif speed >= 0:
                if gear == 1:
                    speed = speed + 10
                    print(f'Speed increased to {speed}')
                    fuel = fuel - 20
                    if fuel <= 0:
                        fuel_notice =  True
                        print('You are out of fuel!')
                        start = False
                        began = False
                        full = False
                        fuel = 0
                        speed = 0
                    elif fuel < 50 and not fuel_notice:
                        print('Your fuel is below 50L')
                elif gear != 1:
                    print('You are in the wrong gear')
                            
        elif not start:
            print('Car is not started yet')
            # speed
    elif command == 'speed':
        if start and not began:
            print(f'You have not accelerated yet!')
        elif not start:
            print('Car is not started!')
        elif start:
            print(f'your speed is {speed} km/hr')
            # deccelerate
    elif command == 'dec':
        if fuel <= 0:
            fuel_notice =  True
            print('You are out of fuel!')
            start = False
            began = False
            full = False
            fuel = 0
            speed = 0
        elif fuel < 50 and not fuel_notice:
            print('Your fuel is below 50L')
        if speed > 0:
            if speed > 180:
                gear = 3
            elif speed > 100:
                gear = 2
            else:
                gear = 1   
            if start and full:
                speed = speed - 10
                fuel = fuel - 5
                
                if speed == 0:
                    start = False
                    began = False
                    print('Your car has stopped!')
                    
                elif speed < 0:
                    speed = 0
                    print('Car cannot be in a negative speed')
                else:
                    print(f'Your speed has decreased to {speed} km/hr')
            elif not start:
                print('Car is not started!')
        elif speed == 0:
            if not start:
                print('Car has not accelerated')
            elif start:
                print("You have'nt accelerated yet!")
             
            # refill
    elif command == 'refill':
        if fuel ==  max_fuel:
            print('Fuel is already full!')
        elif fuel < max_fuel:
            fuel = max_fuel
            print('Your tank has been refilled')
            # fuelling
    elif command == 'fuel':
        print(fuel)

        # help
    elif command == 'help':
        print('''
> help -To display commands
> start - To start the car
> stop - To stop the car
> quit - To exit
> acc - To accelerate your car
> dec - To decelerate your car
> speed - To display your speed
> refill - To refill your tank
> fuel - To display your remaining fuel capacity
> dash - To display your speed and fuel remaining
''')

        
    elif command == 'quit':
        break
    elif command == "dash":
        print(f'''
---- DASHBOARD ----
Speed : {speed} km/hr
Fuel  : {fuel} L
Gear  : {gear}
Started : {start}
-------------------
''')
    elif command == 'gu':
        if gear == 3:
            print('You are at the highest gear')
        elif gear < 3:
            gear += 1
            print(f'You are gear {gear}')
    elif command == 'gd':
        if gear == 1:
            print('You are at the lowest gear')
        elif gear > 1:
            gear -= 1
            print(f'Your gear is down to {gear}')
    else:
        print('Not recognized!')
